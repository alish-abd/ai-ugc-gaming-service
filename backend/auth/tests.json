{
  "tests": [
    {
      "name": "Wrong password returns error",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "login": "nobody@nowhere.com", "password": "wrong"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Missing fields returns error",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "username": "", "email": "", "password": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Telegram invalid hash rejected",
      "method": "POST",
      "path": "/",
      "body": {"action": "telegram", "telegram": {"id": 123, "first_name": "Test", "auth_date": 1700000000, "hash": "deadbeef"}},
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Telegram webapp invalid initData rejected",
      "method": "POST",
      "path": "/",
      "body": {"action": "telegram_webapp", "init_data": "user=%7B%22id%22%3A1%7D&auth_date=1700000000&hash=deadbeef"},
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}